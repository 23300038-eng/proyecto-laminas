<div class="page-header">
    <h2>Editar Usuario</h2>
</div>

<form method="POST" enctype="multipart/form-data" style="max-width: 600px;">
    <div class="form-group">
        <label for="str_nombre_usuario">Nombre de Empleado *</label>
        <input type="text" id="str_nombre_usuario" name="str_nombre_usuario" required placeholder="Ej: Juan Pérez" minlength="3" maxlength="120" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñÜü\s.\-]{3,120}" value="<?php echo htmlspecialchars($usuario['str_nombre_usuario'] ?? ''); ?>">
    </div>

    <div class="form-group">
        <label for="str_correo">Correo Electrónico *</label>
        <input type="email" id="str_correo" name="str_correo" required maxlength="150" placeholder="Ej: juan@novafarma.com" value="<?php echo htmlspecialchars($usuario['str_correo'] ?? ''); ?>">
    </div>

    <div class="form-row">
        <div class="form-group">
            <label for="str_pwd">Contraseña (dejar vacío para no cambiar)</label>
            <input type="password" id="str_pwd" name="str_pwd" minlength="8" maxlength="120" placeholder="••••••••">
        </div>

        <div class="form-group">
            <label for="id_perfil">Perfil *</label>
            <select id="id_perfil" name="id_perfil" required>
                <option value="">-- Seleccionar --</option>
                <?php foreach ($perfiles as $id => $nombre): ?>
                    <option value="<?php echo $id; ?>" <?php echo ($usuario['id_perfil'] ?? null) == $id ? 'selected' : ''; ?>><?php echo htmlspecialchars($nombre); ?></option>
                <?php endforeach; ?>
            </select>
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label for="str_numero_celular">Celular</label>
            <input type="text" id="str_numero_celular" name="str_numero_celular" maxlength="10" inputmode="numeric" pattern="\d{10}" placeholder="5512345678" value="<?php echo htmlspecialchars($usuario['str_numero_celular'] ?? ''); ?>" oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,10)">
        </div>

        <div class="form-group">
            <label for="id_estado_usuario">Estado</label>
            <select id="id_estado_usuario" name="id_estado_usuario">
                <option value="">-- Seleccionar --</option>
                <?php foreach ($estados as $id => $nombre): ?>
                    <option value="<?php echo $id; ?>" <?php echo ($usuario['id_estado_usuario'] ?? null) == $id ? 'selected' : ''; ?>><?php echo htmlspecialchars($nombre); ?></option>
                <?php endforeach; ?>
            </select>
        </div>
    </div>

    <div class="btn-group" style="margin-top: 2rem;">
        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a href="/security/usuario" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const phone = document.getElementById('str_numero_celular');
  if (phone) {
    phone.addEventListener('input', function () {
      this.value = this.value.replace(/\D+/g, '').slice(0, 10);
    });
  }
});
</script>
