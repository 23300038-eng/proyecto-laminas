<nav class="breadcrumbs">
	<a href="<?= $this->url('dashboard', ['action'=>'index']) ?>">Dashboard</a>
	<span>/</span>
	<a href="<?= $this->url('security', ['action'=>'perfil']) ?>">Administración</a>
	<span>/</span>
	<span>Perfiles</span>
</nav>

<div class="page-header">
	<h2>Gestión de Perfiles</h2>
	<a href="<?= $this->url('security', ['action'=>'perfil-add']) ?>" class="btn btn-primary">+ Crear Perfil</a>
</div>

<?php if (!empty($success)): ?>
	<div class="alert alert-success">
		<?php echo htmlspecialchars($success); ?>
	</div>
<?php endif; ?>

<?php if (!empty($error)): ?>
	<div class="alert alert-error">
		<?php echo htmlspecialchars($error); ?>
	</div>
<?php endif; ?>

<div class="table-container">
	<table class="table">
		<thead>
			<tr>
				<th>ID</th>
				<th>Nombre del Perfil</th>
				<th>Administrador</th>
				<th>Descripción</th>
				<th style="text-align: center;">Acciones</th>
			</tr>
		</thead>
		<tbody>
			<?php if (!empty($perfiles) && count($perfiles) > 0): ?>
				<?php foreach ($perfiles as $perfil): ?>
					<tr>
						<td><strong><?php echo htmlspecialchars($perfil['id']); ?></strong></td>
						<td><?php echo htmlspecialchars($perfil['str_nombre_perfil']); ?></td>
						<td>
							<?php if ($perfil['bit_administrador']): ?>
								<span class="badge badge-success">Sí</span>
							<?php else: ?>
								<span class="badge badge-secondary">No</span>
							<?php endif; ?>
						</td>
						<td><?php echo htmlspecialchars(substr($perfil['descripcion'] ?? '', 0, 50)) . (strlen($perfil['descripcion'] ?? '') > 50 ? '...' : ''); ?></td>
						<td style="text-align: center;">
							<div class="btn-group">
								<a href="<?= $this->url('security', ['action'=>'perfil-detalle', 'id'=>$perfil['id']]) ?>" class="btn btn-sm btn-secondary" title="Ver detalles">Ver</a>
								<a href="<?= $this->url('security', ['action'=>'perfil-edit', 'id'=>$perfil['id']]) ?>" class="btn btn-sm btn-secondary" title="Editar">Editar</a>
								<a href="<?= $this->url('security', ['action'=>'perfil', 'delete'=>$perfil['id']]) ?>" class="btn btn-sm btn-danger" title="Eliminar" onclick="return confirm('¿Está seguro que desea eliminar este perfil?')">Eliminar</a>
							</div>
						</td>
					</tr>
				<?php endforeach; ?>
			<?php else: ?>
				<tr>
					<td colspan="5" class="empty-state">
						<p>No hay perfiles registrados en el sistema.</p>
					</td>
				</tr>
			<?php endif; ?>
		</tbody>
	</table>
</div>

<?php if (!empty($pages) && $pages > 1): ?>
	<div class="pagination">
		<?php if ($page > 1): ?>
			<a href="?page=1" title="Primera página">« Primera</a>
			<a href="?page=<?php echo $page - 1; ?>" title="Página anterior">‹ Anterior</a>
		<?php endif; ?>

		<?php for ($i = 1; $i <= $pages; $i++): ?>
			<?php if ($i === $page): ?>
				<span class="pagination-current"><?php echo $i; ?></span>
			<?php else: ?>
				<a href="?page=<?php echo $i; ?>"><?php echo $i; ?></a>
			<?php endif; ?>
		<?php endfor; ?>

		<?php if ($page < $pages): ?>
			<a href="?page=<?php echo $page + 1; ?>" title="Siguiente página">Siguiente ›</a>
			<a href="?page=<?php echo $pages; ?>" title="Última página">Última »</a>
		<?php endif; ?>
	</div>
<?php endif; ?>
