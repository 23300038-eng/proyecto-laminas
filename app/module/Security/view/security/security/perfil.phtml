<?php
// Permisos del usuario actual para este módulo
$esAdmin = !empty($_SESSION['bit_administrador'] ?? false);
$p = $permisos_modulo ?? ['agregar'=>$esAdmin,'editar'=>$esAdmin,'consulta'=>$esAdmin,'eliminar'=>$esAdmin,'detalle'=>$esAdmin];
?>
<nav class="breadcrumbs">
    <a href="<?= $this->url('dashboard', ['action'=>'index']) ?>">Dashboard</a>
    <span>/</span>
    <span>Seguridad</span>
    <span>/</span>
    <span>Perfiles</span>
</nav>

<div class="page-header">
    <h2>Gestión de Perfiles</h2>
    <?php if ($p['agregar']): ?>
        <a href="<?= $this->url('security', ['action'=>'perfil-add']) ?>" class="btn btn-primary">+ Crear Perfil</a>
    <?php endif; ?>
</div>

<?php if (!empty($success)): ?>
    <div class="alert alert-success"><?= htmlspecialchars($success) ?></div>
<?php endif; ?>
<?php if (!empty($error)): ?>
    <div class="alert alert-error"><?= htmlspecialchars($error) ?></div>
<?php endif; ?>

<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre del Perfil</th>
                <th>Administrador</th>
                <th>Descripción</th>
                <?php if ($p['detalle'] || $p['editar'] || $p['eliminar']): ?>
                    <th style="text-align:center">Acciones</th>
                <?php endif; ?>
            </tr>
        </thead>
        <tbody>
            <?php if (!empty($perfiles)): ?>
                <?php foreach ($perfiles as $perfil): ?>
                    <tr>
                        <td><strong><?= htmlspecialchars($perfil['id']) ?></strong></td>
                        <td><?= htmlspecialchars($perfil['str_nombre_perfil']) ?></td>
                        <td>
                            <?php if ($perfil['bit_administrador']): ?>
                                <span class="badge badge-success">Sí</span>
                            <?php else: ?>
                                <span class="badge badge-secondary">No</span>
                            <?php endif; ?>
                        </td>
                        <td><?= htmlspecialchars(substr($perfil['descripcion'] ?? '', 0, 50)) ?><?= strlen($perfil['descripcion'] ?? '') > 50 ? '…' : '' ?></td>
                        <?php if ($p['detalle'] || $p['editar'] || $p['eliminar']): ?>
                            <td style="text-align:center">
                                <div class="btn-group">
                                    <?php if ($p['detalle']): ?>
                                        <a href="<?= $this->url('security', ['action'=>'perfil-detalle','id'=>$perfil['id']]) ?>" class="btn btn-sm btn-secondary">Ver</a>
                                    <?php endif; ?>
                                    <?php if ($p['editar']): ?>
                                        <a href="<?= $this->url('security', ['action'=>'perfil-edit','id'=>$perfil['id']]) ?>" class="btn btn-sm btn-secondary">Editar</a>
                                    <?php endif; ?>
                                    <?php if ($p['eliminar']): ?>
                                        <a href="<?= $this->url('security', ['action'=>'perfil-delete','id'=>$perfil['id']]) ?>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este perfil?')">Eliminar</a>
                                    <?php endif; ?>
                                </div>
                            </td>
                        <?php endif; ?>
                    </tr>
                <?php endforeach; ?>
            <?php else: ?>
                <tr><td colspan="5" class="empty-state"><p>No hay perfiles registrados.</p></td></tr>
            <?php endif; ?>
        </tbody>
    </table>
</div>

<?php if (!empty($pages) && $pages > 1): ?>
    <div class="pagination">
        <?php if ($page > 1): ?>
            <a href="?page=1">« Primera</a>
            <a href="?page=<?= $page - 1 ?>">‹ Anterior</a>
        <?php endif; ?>
        <?php for ($i = 1; $i <= $pages; $i++): ?>
            <?php if ($i === $page): ?>
                <span class="pagination-current"><?= $i ?></span>
            <?php else: ?>
                <a href="?page=<?= $i ?>"><?= $i ?></a>
            <?php endif; ?>
        <?php endfor; ?>
        <?php if ($page < $pages): ?>
            <a href="?page=<?= $page + 1 ?>">Siguiente ›</a>
            <a href="?page=<?= $pages ?>">Última »</a>
        <?php endif; ?>
    </div>
<?php endif; ?>
