<div class="page-header">
    <h2>Crear Nuevo Módulo</h2>
</div>

<form method="POST" style="max-width: 600px;">
    <div class="form-group">
        <label for="str_nombre_modulo">Nombre del Módulo *</label>
        <input type="text" id="str_nombre_modulo" name="str_nombre_modulo" required placeholder="Ej: Inventario, Reportes">
    </div>

    <div class="form-row">
        <div class="form-group">
            <label for="str_icono">Icono</label>
            <input type="text" id="str_icono" name="str_icono" placeholder="Ej: lock, home, cog">
        </div>

        <div class="form-group">
            <label for="int_orden">Orden</label>
            <input type="number" id="int_orden" name="int_orden" value="0" placeholder="Ej: 1, 2, 3">
        </div>
    </div>

    <div class="form-check">
        <input type="checkbox" id="bit_activo" name="bit_activo" value="1" checked>
        <label for="bit_activo">¿Activo?</label>
    </div>

    <div class="btn-group" style="margin-top: 2rem;">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/security/modulo" class="btn btn-secondary">Cancelar</a>
    </div>
</form>
