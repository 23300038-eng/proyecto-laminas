<nav class="breadcrumbs">
    <a href="<?= $this->url('dashboard', ['action'=>'index']) ?>">Dashboard</a>
    <span>/</span>
    <a href="<?= $this->url('security', ['action'=>'perfil']) ?>">Administración</a>
    <span>/</span>
    <span>Usuarios</span>
</nav>

<div class="page-header">
    <h2>Gestión de Usuarios</h2>
    <a href="<?= $this->url('security', ['action'=>'usuario-add']) ?>" class="btn btn-primary">+ Crear Usuario</a>
</div>

<?php if (!empty($success)): ?>
    <div class="alert alert-success">
        <?php echo htmlspecialchars($success); ?>
    </div>
<?php endif; ?>

<?php if (!empty($error)): ?>
    <div class="alert alert-error">
        <?php echo htmlspecialchars($error); ?>
    </div>
<?php endif; ?>

<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Usuario</th>
                <th>Correo</th>
                <th>Perfil</th>
                <th>Estado</th>
                <th style="text-align: center;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <?php if (!empty($usuarios) && count($usuarios) > 0): ?>
                <?php foreach ($usuarios as $usuario): ?>
                    <tr>
                        <td><strong><?php echo htmlspecialchars($usuario['id']); ?></strong></td>
                        <td><?php echo htmlspecialchars($usuario['str_nombre_usuario']); ?></td>
                        <td><?php echo htmlspecialchars($usuario['str_correo']); ?></td>
                        <td><?php echo htmlspecialchars($usuario['str_nombre_perfil'] ?? 'N/A'); ?></td>
                        <td>
                            <?php $estado = htmlspecialchars($usuario['str_nombre'] ?? ''); ?>
                            <?php if (stripos($estado, 'activo') !== false): ?>
                                <span class="badge badge-success"><?php echo $estado; ?></span>
                            <?php else: ?>
                                <span class="badge badge-secondary"><?php echo $estado; ?></span>
                            <?php endif; ?>
                        </td>
                        <td style="text-align: center;">
                            <div class="btn-group">
                                <a href="<?= $this->url('security', ['action'=>'usuario-detalle', 'id'=>$usuario['id']]) ?>" class="btn btn-sm btn-secondary" title="Ver detalles">Ver</a>
                                <a href="<?= $this->url('security', ['action'=>'usuario-edit', 'id'=>$usuario['id']]) ?>" class="btn btn-sm btn-secondary" title="Editar">Editar</a>
                                <a href="<?= $this->url('security', ['action'=>'usuario', 'delete'=>$usuario['id']]) ?>" class="btn btn-sm btn-danger" title="Eliminar" onclick="return confirm('¿Está seguro que desea eliminar este usuario?')">Eliminar</a>
                            </div>
                        </td>
                    </tr>
                <?php endforeach; ?>
            <?php else: ?>
                <tr>
                    <td colspan="6" class="empty-state">
                        <p>No hay usuarios registrados en el sistema.</p>
                    </td>
                </tr>
            <?php endif; ?>
        </tbody>
    </table>
</div>

<?php if (!empty($pages) && $pages > 1): ?>
    <div class="pagination">
        <?php if ($page > 1): ?>
            <a href="?page=1" title="Primera página">« Primera</a>
            <a href="?page=<?php echo $page - 1; ?>" title="Página anterior">‹ Anterior</a>
        <?php endif; ?>

        <?php for ($i = 1; $i <= $pages; $i++): ?>
            <?php if ($i === $page): ?>
                <span class="pagination-current"><?php echo $i; ?></span>
            <?php else: ?>
                <a href="?page=<?php echo $i; ?>"><?php echo $i; ?></a>
            <?php endif; ?>
        <?php endfor; ?>

        <?php if ($page < $pages): ?>
            <a href="?page=<?php echo $page + 1; ?>" title="Siguiente página">Siguiente ›</a>
            <a href="?page=<?php echo $pages; ?>" title="Última página">Última »</a>
        <?php endif; ?>
    </div>
<?php endif; ?>
