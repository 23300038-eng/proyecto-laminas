<div class="page-header">
    <h2>Gestión de Permisos-Perfil</h2>
    <a href="/security/permiso-perfil-add" class="btn btn-primary">+ Crear Permiso</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Módulo</th>
            <th>Perfil</th>
            <th>Crear</th>
            <th>Editar</th>
            <th>Consultar</th>
            <th>Eliminar</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        <?php if (count($permisos) > 0): ?>
            <?php foreach ($permisos as $permiso): ?>
                <tr>
                    <td><?php echo htmlspecialchars($permiso['id']); ?></td>
                    <td><?php echo htmlspecialchars($permiso['str_nombre_modulo']); ?></td>
                    <td><?php echo htmlspecialchars($permiso['str_nombre_perfil']); ?></td>
                    <td><?php echo $permiso['bit_agregar'] ? '✓' : '✗'; ?></td>
                    <td><?php echo $permiso['bit_editar'] ? '✓' : '✗'; ?></td>
                    <td><?php echo $permiso['bit_consulta'] ? '✓' : '✗'; ?></td>
                    <td><?php echo $permiso['bit_eliminar'] ? '✓' : '✗'; ?></td>
                    <td>
                        <div class="btn-group">
                            <a href="/security/permiso-perfil-detalle/<?php echo $permiso['id']; ?>" class="btn btn-secondary" title="Ver">👁️</a>
                            <a href="/security/permiso-perfil-edit/<?php echo $permiso['id']; ?>" class="btn btn-secondary" title="Editar">✏️</a>
                            <a href="/security/permiso-perfil-delete/<?php echo $permiso['id']; ?>" class="btn btn-danger" title="Eliminar" onclick="return confirm('¿Está seguro?')">🗑️</a>
                        </div>
                    </td>
                </tr>
            <?php endforeach; ?>
        <?php else: ?>
            <tr>
                <td colspan="8" style="text-align: center; padding: 2rem;">No hay permisos registrados</td>
            </tr>
        <?php endif; ?>
    </tbody>
</table>

<?php if ($pages > 1): ?>
    <div class="pagination">
        <?php if ($page > 1): ?>
            <a href="?page=1">« Primera</a>
            <a href="?page=<?php echo $page - 1; ?>">‹ Anterior</a>
        <?php endif; ?>

        <?php for ($i = 1; $i <= $pages; $i++): ?>
            <?php if ($i === $page): ?>
                <span class="active"><?php echo $i; ?></span>
            <?php else: ?>
                <a href="?page=<?php echo $i; ?>"><?php echo $i; ?></a>
            <?php endif; ?>
        <?php endfor; ?>

        <?php if ($page < $pages): ?>
            <a href="?page=<?php echo $page + 1; ?>">Siguiente ›</a>
            <a href="?page=<?php echo $pages; ?>">Última »</a>
        <?php endif; ?>
    </div>
<?php endif; ?>
