</div>

<?php if (!empty($error)): ?>
    <div class="alert alert-error"><?= htmlspecialchars($error) ?></div>
<?php endif; ?>

<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre del Módulo</th>
                <th>Ícono</th>
                <th>Orden</th>
                <th>Activo</th>
                <?php if ($p['detalle'] || $p['editar'] || $p['eliminar']): ?>
                    <th style="text-align:center">Acciones</th>
                <?php endif; ?>
            </tr>
        </thead>
        <tbody>
            <?php if (!empty($modulos)): ?>
                <?php foreach ($modulos as $modulo): ?>
                    <tr>
                        <td><strong><?= htmlspecialchars($modulo['id']) ?></strong></td>
                        <td><?= htmlspecialchars($modulo['str_nombre_modulo']) ?></td>
                        <td><?= htmlspecialchars($modulo['str_icono'] ?? '-') ?></td>
                        <td><?= htmlspecialchars($modulo['int_orden'] ?? 0) ?></td>
                        <td>
                            <?php if ($modulo['bit_activo']): ?>
                                <span class="badge badge-success">Activo</span>
                            <?php else: ?>
                                <span class="badge badge-secondary">Inactivo</span>
                            <?php endif; ?>
                        </td>
                        <?php if ($p['detalle'] || $p['editar'] || $p['eliminar']): ?>
                            <td style="text-align:center">
                                <div class="btn-group">
                                    <?php if ($p['detalle']): ?>
                                        <a href="<?= $this->url('security', ['action'=>'modulo-detalle','id'=>$modulo['id']]) ?>" class="btn btn-sm btn-secondary">Ver</a>
                                    <?php endif; ?>
                                    <?php if ($p['editar']): ?>
                                        <a href="<?= $this->url('security', ['action'=>'modulo-edit','id'=>$modulo['id']]) ?>" class="btn btn-sm btn-secondary">Editar</a>
                                    <?php endif; ?>
                                    <?php if ($p['eliminar']): ?>
                                        <a href="<?= $this->url('security', ['action'=>'modulo-delete','id'=>$modulo['id']]) ?>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este módulo?')">Eliminar</a>
