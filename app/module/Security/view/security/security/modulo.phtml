<div class="page-header">
    <h2>Gestión de Módulos</h2>
    <a href="/security/modulo-add" class="btn btn-primary">+ Crear Módulo</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Icono</th>
            <th>Orden</th>
            <th>Activo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        <?php if (count($modulos) > 0): ?>
            <?php foreach ($modulos as $modulo): ?>
                <tr>
                    <td><?php echo htmlspecialchars($modulo['id']); ?></td>
                    <td><?php echo htmlspecialchars($modulo['str_nombre_modulo']); ?></td>
                    <td><?php echo htmlspecialchars($modulo['str_icono'] ?? ''); ?></td>
                    <td><?php echo htmlspecialchars($modulo['int_orden']); ?></td>
                    <td><?php echo $modulo['bit_activo'] ? 'Sí' : 'No'; ?></td>
                    <td>
                        <div class="btn-group">
                            <a href="/security/modulo-detalle/<?php echo $modulo['id']; ?>" class="btn btn-secondary" title="Ver">👁️</a>
                            <a href="/security/modulo-edit/<?php echo $modulo['id']; ?>" class="btn btn-secondary" title="Editar">✏️</a>
                            <a href="/security/modulo-delete/<?php echo $modulo['id']; ?>" class="btn btn-danger" title="Eliminar" onclick="return confirm('¿Está seguro?')">🗑️</a>
                        </div>
                    </td>
                </tr>
            <?php endforeach; ?>
        <?php else: ?>
            <tr>
                <td colspan="6" style="text-align: center; padding: 2rem;">No hay módulos registrados</td>
            </tr>
        <?php endif; ?>
    </tbody>
</table>

<?php if ($pages > 1): ?>
    <div class="pagination">
        <?php if ($page > 1): ?>
            <a href="?page=1">« Primera</a>
            <a href="?page=<?php echo $page - 1; ?>">‹ Anterior</a>
        <?php endif; ?>

        <?php for ($i = 1; $i <= $pages; $i++): ?>
            <?php if ($i === $page): ?>
                <span class="active"><?php echo $i; ?></span>
            <?php else: ?>
                <a href="?page=<?php echo $i; ?>"><?php echo $i; ?></a>
            <?php endif; ?>
        <?php endfor; ?>

        <?php if ($page < $pages): ?>
            <a href="?page=<?php echo $page + 1; ?>">Siguiente ›</a>
            <a href="?page=<?php echo $pages; ?>">Última »</a>
        <?php endif; ?>
    </div>
<?php endif; ?>
