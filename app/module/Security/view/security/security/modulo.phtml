            <?php else: ?>
                <tr><td colspan="6" class="empty-state"><p>No hay módulos registrados.</p></td></tr>
            <?php endif; ?>
        </tbody>
    </table>
</div>

<?php if (!empty($pages) && $pages > 1): ?>
    <div class="pagination">
        <?php if ($page > 1): ?>
            <a href="?page=1">« Primera</a>
            <a href="?page=<?= $page - 1 ?>">‹ Anterior</a>
        <?php endif; ?>
        <?php for ($i = 1; $i <= $pages; $i++): ?>
            <?php if ($i === $page): ?>
                <span class="pagination-current"><?= $i ?></span>
            <?php else: ?>
                <a href="?page=<?= $i ?>"><?= $i ?></a>
            <?php endif; ?>
        <?php endfor; ?>
        <?php if ($page < $pages): ?>
            <a href="?page=<?= $page + 1 ?>">Siguiente ›</a>
            <a href="?page=<?= $pages ?>">Última »</a>
        <?php endif; ?>
    </div>
<?php endif; ?>
