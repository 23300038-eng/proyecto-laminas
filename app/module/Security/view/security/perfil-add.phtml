<div class="page-header">
    <h2>Crear Nuevo Perfil</h2>
</div>

<form method="POST" style="max-width: 600px;">
    <div class="form-group">
        <label for="str_nombre_perfil">Nombre del Perfil *</label>
        <input type="text" id="str_nombre_perfil" name="str_nombre_perfil" required placeholder="Ej: Gerente, Empleado">
    </div>

    <div class="form-group">
        <label for="descripcion">Descripción</label>
        <textarea id="descripcion" name="descripcion" placeholder="Describa el propósito de este perfil"></textarea>
    </div>

    <div class="form-check">
        <input type="checkbox" id="bit_administrador" name="bit_administrador" value="1">
        <label for="bit_administrador">¿Es administrador?</label>
    </div>

    <div class="btn-group" style="margin-top: 2rem;">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/security/perfil" class="btn btn-secondary">Cancelar</a>
    </div>
</form>
