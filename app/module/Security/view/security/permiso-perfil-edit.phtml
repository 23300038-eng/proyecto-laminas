        </div>
    </div>

    <fieldset style="border: 1px solid #ddd; padding: 1rem; border-radius: 4px; margin: 1.5rem 0;">
        <legend style="padding: 0 0.5rem;">Permisos</legend>

        <div class="form-check">
            <input type="checkbox" id="bit_agregar" name="bit_agregar" value="1" <?php echo ($permiso['bit_agregar'] ?? false) ? 'checked' : ''; ?>>
