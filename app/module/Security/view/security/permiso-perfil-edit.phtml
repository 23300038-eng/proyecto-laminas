            <input type="hidden" name="id_modulo" value="<?php echo htmlspecialchars($permiso['id_modulo']); ?>">
        </div>

        <div class="form-group">
            <label for="id_perfil">Perfil (No editable)</label>
            <input type="text" disabled value="<?php echo htmlspecialchars($permiso['str_nombre_perfil']); ?>">
