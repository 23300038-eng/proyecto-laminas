<?php
/**
 * @var Laminas\View\Renderer\PhpRenderer $this
 * @var array   $usuarios   Registros de la página actual
 * @var string  $search     Término de búsqueda
 * @var int     $page       Página actual
 * @var int     $totalPages Total de páginas
 * @var int     $total      Total de registros encontrados
 */

// Helper para construir URLs conservando search y cambiando page
$buildUrl = function (int $page, string $search = ''): string {
    $params = ['page' => $page];

    if ($search !== '') {
        $params['search'] = $search;
    }

    return $this->url(
        'application/default',
        ['action' => 'crudSegundaEvaluacion'],
        ['query' => $params]
    );
};
?>
<div class="container" style="min-height:100vh; background-color:rgb(240,240,240)">
<nav aria-label="breadcrumb mt-5">
<ol class="breadcrumb">
<li class="breadcrumb-item"><a href="<?= $this->url('application/default', ['action' => 'index']) ?>">Inicio</a></li>
<li class="breadcrumb-item active" aria-current="page">Crud Segunda Evaluación</li>
</ol>
</nav>

<div class="ms-5 ps-5 pe-5 pb-3 pt-2 d-flex align-items-center">
<a href="<?= $this->url('application/default', ['action' => 'index']) ?>" class="btn btn-dark p-2 me-3">&lt;-</a>
<span class="title text-center fs-2">Crud Segunda Evaluación</span>
</div>

<div class="container pb-5">

    <!-- Fila: Botón agregar + Buscador -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">

        <a href="<?= $this->url('application/default', ['action' => 'addUsuario']) ?>" class="btn btn-dark">
            <i class="bi bi-plus-lg"></i> Agregar Nuevo Usuario
        </a>

        <form method="GET"
              action="<?= $this->url('application/default', ['action' => 'crudSegundaEvaluacion']) ?>"
              class="d-flex gap-2"
              style="max-width:440px; width:100%">
            <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Buscar por nombre, apellido, correo…"
                value="<?= $this->escapeHtml($search) ?>"
                autocomplete="off"
            >
            <button type="submit" class="btn btn-primary px-3">
                <i class="bi bi-search"></i> Buscar
            </button>
            <?php if ($search !== ''): ?>
                <a href="<?= $this->url('application/default', ['action' => 'crudSegundaEvaluacion']) ?>"
                   class="btn btn-outline-secondary" title="Limpiar">✕</a>
            <?php endif ?>
        </form>
    </div>

    <!-- Contador de resultados -->
    <p class="text-muted small mb-2">
        <?php if ($search !== ''): ?>
            Se encontraron <strong><?= $total ?></strong> resultado(s) para
            "<strong><?= $this->escapeHtml($search) ?></strong>".
        <?php else: ?>
            Total de usuarios: <strong><?= $total ?></strong>
        <?php endif ?>
        &nbsp;|&nbsp; Página <strong><?= $page ?></strong> de <strong><?= $totalPages ?></strong>
    </p>

    <!-- Tabla -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered bg-white table-hover align-middle">
        <thead class="table-dark">
        <tr>
        <th>Nombre</th>
        <th>Apellido Paterno</th>
        <th>Apellido Materno</th>
        <th>Teléfono</th>
        <th>Correo</th>
        <th>Nacimiento</th>
        <th>Acciones</th>
        </tr>
        </thead>
        <tbody>
        <?php if (count($usuarios) === 0): ?>
        <tr>
        <td colspan="7" class="text-center py-4 text-muted">
            <?php if ($search !== ''): ?>
                No se encontraron usuarios para "<strong><?= $this->escapeHtml($search) ?></strong>".
            <?php else: ?>
                No hay registros.
            <?php endif ?>
        </td>
        </tr>
        <?php else: ?>
        <?php foreach ($usuarios as $usuario): ?>
        <tr data-id="<?= $usuario['id'] ?>">
        <td><?= $this->escapeHtml($usuario['nombre']) ?></td>
        <td><?= $this->escapeHtml($usuario['apellido_pat']) ?></td>
        <td><?= $this->escapeHtml($usuario['apellido_mat']) ?></td>
        <td><?= $this->escapeHtml($usuario['telefono']) ?></td>
        <td><?= $this->escapeHtml($usuario['correo']) ?></td>
        <td><?= $this->escapeHtml($usuario['nacimiento']) ?></td>
        <td>
            <button class="btn btn-sm btn-warning btn-edit"
                    data-id="<?= $this->escapeHtml($usuario['id'] ?? '') ?>"
                    onclick="window.location.href='<?= $this->url('application/editUsuario', ['id' => '']) ?>' + this.getAttribute('data-id')">
                <i class="bi bi-pencil"></i> Editar
            </button>
            <button class="btn btn-sm btn-danger btn-delete ms-1"
                    data-id="<?= $usuario['id'] ?>"
                    data-nombre="<?= $this->escapeHtml($usuario['nombre'] . ' ' . $usuario['apellido_pat']) ?>"
                    title="Eliminar">
                <i class="bi bi-trash"></i> Eliminar
            </button>
        </td>
        </tr>
        <?php endforeach; ?>
        <?php endif; ?>
        </tbody>
        </table>
    </div>

    <!-- Paginación -->
    <?php if ($totalPages > 1): ?>
    <nav aria-label="Paginación de usuarios">
        <ul class="pagination justify-content-center flex-wrap mt-2">

            <!-- Primera -->
            <li class="page-item <?= $page <= 1 ? 'disabled' : '' ?>">
                <a class="page-link" href="<?= $page > 1 ? $buildUrl(1, $search) : '#' ?>">
                    |&laquo; Primera
                </a>
            </li>

            <!-- Anterior -->
            <li class="page-item <?= $page <= 1 ? 'disabled' : '' ?>">
                <a class="page-link" href="<?= $page > 1 ? $buildUrl($page - 1, $search) : '#' ?>">
                    &laquo; Anterior
                </a>
            </li>

            <?php
            $window = 2;
            $start  = max(1, $page - $window);
            $end    = min($totalPages, $page + $window);
            ?>

            <?php if ($start > 1): ?>
                <li class="page-item"><a class="page-link" href="<?= $buildUrl(1, $search) ?>">1</a></li>
                <?php if ($start > 2): ?>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                <?php endif ?>
            <?php endif ?>

            <?php for ($i = $start; $i <= $end; $i++): ?>
                <li class="page-item <?= $i === $page ? 'active' : '' ?>">
                    <a class="page-link" href="<?= $buildUrl($i, $search) ?>"><?= $i ?></a>
                </li>
            <?php endfor ?>

            <?php if ($end < $totalPages): ?>
                <?php if ($end < $totalPages - 1): ?>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                <?php endif ?>
                <li class="page-item"><a class="page-link" href="<?= $buildUrl($totalPages, $search) ?>"><?= $totalPages ?></a></li>
            <?php endif ?>

            <!-- Siguiente -->
            <li class="page-item <?= $page >= $totalPages ? 'disabled' : '' ?>">
                <a class="page-link" href="<?= $page < $totalPages ? $buildUrl($page + 1, $search) : '#' ?>">
                    Siguiente &raquo;
                </a>
            </li>

            <!-- Última -->
            <li class="page-item <?= $page >= $totalPages ? 'disabled' : '' ?>">
                <a class="page-link" href="<?= $page < $totalPages ? $buildUrl($totalPages, $search) : '#' ?>">
                    Última &raquo;|
                </a>
            </li>

        </ul>
    </nav>
    <?php endif ?>

</div>
</div>

<!-- Modal de confirmación de eliminación (Bootstrap) -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
<div class="modal-dialog">
<div class="modal-content">
  <div class="modal-header">
    <h5 class="modal-title" id="deleteModalLabel">Confirmar eliminación</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
  </div>
  <div class="modal-body">
    ¿Realmente deseas eliminar al usuario <strong id="usuarioNombre"></strong>?
  </div>
  <div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
    <button type="button" class="btn btn-danger" id="confirmDelete">Eliminar</button>
  </div>
</div>
</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  let usuarioIdToDelete = null;

  // Botón Eliminar
  document.querySelectorAll('.btn-delete').forEach(button => {
    button.addEventListener('click', function () {
      usuarioIdToDelete = this.getAttribute('data-id');
      const nombre = this.getAttribute('data-nombre');

      document.getElementById('usuarioNombre').textContent = nombre;
      const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
      modal.show();
    });
  });

  // Confirmar eliminación
  document.getElementById('confirmDelete').addEventListener('click', function () {
    if (!usuarioIdToDelete) return;

    fetch("<?= $this->url('application/default', ['action' => 'deleteUsuario']) ?>", {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ id: usuarioIdToDelete })
    })
    .then(response => {
      if (!response.ok) {
        return response.text().then(text => { throw new Error(text || 'Error ' + response.status); });
      }
      return response.json();
    })
    .then(result => {
      if (result.success) {
        // Remover fila de la tabla
        const row = document.querySelector(`tr[data-id="${usuarioIdToDelete}"]`);
        if (row) row.remove();

        alert(result.message || 'Usuario eliminado correctamente');

        // Recargar si la tabla quedó vacía (para actualizar paginación)
        const remainingRows = document.querySelectorAll('tbody tr[data-id]');
        if (remainingRows.length === 0) {
          window.location.reload();
        }
      } else {
        alert('Error: ' + (result.message || 'No se pudo eliminar el usuario'));
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error al eliminar: ' + error.message);
    })
    .finally(() => {
      bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
      usuarioIdToDelete = null;
    });
  });

});
</script>